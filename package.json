{
  "name": "@euriklis/quadprog",
  "version": "2.0.2",
  "description": "A TypeScript implementation of the quadprog (Goldfarb-Idnani) quadratic programming solver, with an optional parallel factorisation.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "node test/quadprog.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prebenchmark": "npm run build",
    "benchmark": "node benchmark/compare.js",
    "benchmark:node": "node benchmark/benchmark.js",
    "benchmark:bun": "bun benchmark/benchmark.js",
    "benchmark:constraints": "node benchmark/constraints.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VelislavKarastoychev/euriklis-quadprog.git"
  },
  "keywords": [
    "typescript",
    "typescript-quadprog",
    "quadprog-typescript",
    "qp-solver",
    "quadprog",
    "solveQP",
    "solveQPFast",
    "quadratic programming",
    "Mathematical programming",
    "optimization",
    "dual algorithm for quadratic programming",
    "Goldfarb-Idnani",
    "active set method",
    "parallel",
    "SharedArrayBuffer",
    "SVM",
    "qpgen2",
    "dpofa",
    "dposl",
    "dpori"
  ],
  "author": "Euriklis <vskarastoychev@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/VelislavKarastoychev/euriklis-quadprog/issues"
  },
  "homepage": "https://github.com/VelislavKarastoychev/euriklis-quadprog#readme",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "quadprog": "^1.6.1",
    "typescript": "^5.9.3"
  }
}
